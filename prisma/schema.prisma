generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model SiteSettings {
  id            String   @id @default("site")
  brandName     String
  brandBadge    String
  footerSummary String
  contactEmail  String
  githubUrl     String
  deployUrl     String
  navigation    Json
  footerLinks   Json
  updatedAt     DateTime @updatedAt
}

model Page {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  heroEyebrow String
  heroTitle   String
  heroBody    String
  content     Json
  status      PublishStatus @default(PUBLISHED)
  updatedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Project {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  category     String
  summary      String
  year         String
  phaseLabel   String
  stack        String[]
  challenge    String
  solution     String
  outcome      String
  deliverables String[]
  status       PublishStatus @default(PUBLISHED)
  updatedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  category    String
  title       String
  summary     String
  readTime    String
  body        Json
  status      PublishStatus @default(PUBLISHED)
  publishedAt DateTime?
  updatedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Asset {
  id        String   @id @default(cuid())
  fileName  String
  url       String
  alt       String?
  mimeType  String
  createdAt DateTime @default(now())
}
